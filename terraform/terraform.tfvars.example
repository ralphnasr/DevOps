# ══════════════════════════════════════════════════════════════
# ShopCloud — Terraform inputs template
# Copy to terraform.tfvars and fill in the values for your account.
# terraform.tfvars is gitignored; this .example file is committed.
#
# Bootstrap (one-time, before `terraform init`):
#   aws s3api create-bucket --bucket shopcloud-tfstate-503q-<ACCOUNT_ID> --region us-east-1
#   aws s3api put-bucket-versioning --bucket shopcloud-tfstate-503q-<ACCOUNT_ID> --versioning-configuration Status=Enabled
#   aws s3api put-bucket-encryption  --bucket shopcloud-tfstate-503q-<ACCOUNT_ID> --server-side-encryption-configuration file://enc.json
#   aws dynamodb create-table --table-name shopcloud-tfstate-lock \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH \
#     --billing-mode PAY_PER_REQUEST --region us-east-1
#   (update the `bucket` value in providers.tf to match)
# ══════════════════════════════════════════════════════════════

aws_region = "us-east-1"

# Bastion: your public IP (append /32) + an SSH public key you own.
admin_cidr_blocks  = ["YOUR.PUBLIC.IP.HERE/32"]
bastion_key_name   = "shopcloud-bastion"
bastion_public_key = "ssh-ed25519 AAAA...REPLACE_WITH_CONTENTS_OF_~/.ssh/id_ed25519.pub you@host"

# SES sender — must be an address you can verify (click the link AWS emails
# you after the first `terraform apply`).
ses_verified_email = "you@example.com"

# Optional custom domain. Leave blank to use the free CloudFront DNS.
domain_name = ""

# Cognito callback URLs.
# First `terraform apply` uses localhost (CloudFront domain is not yet known).
# Second pass, override via -var to include the real CloudFront URL — see deploy.sh.
customer_callback_urls = ["http://localhost:3000/callback.html"]
customer_logout_urls   = ["http://localhost:3000/index.html"]
admin_callback_urls    = ["http://localhost:8001/admin"]
admin_logout_urls      = ["http://localhost:8001/admin"]
